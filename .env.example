# Embedding provider: "local" (HuggingFace) or "openrouter"
EMBEDDING_PROVIDER=local

# Local embedding model (hf sentence-transformers)
EMBEDDING_MODEL_NAME=all-mpnet-base-v2

# OpenRouter embedding model
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large

# FAISS vector store path
FAISS_INDEX_PATH=data/vector_store
INDEX_SNAPSHOTS_ROOT_PATH=data/indexes
ACTIVE_INDEX_STATE_PATH=data/runtime/active_indexes.json
RUNTIME_SETTINGS_PATH=data/runtime/settings.json
USAGE_LOG_PATH=data/runtime/usage_log.jsonl
DOCUMENTS_SYNC_STATE_PATH=data/runtime/documents_sync_state.json
DOCUMENTS_TYPESENSE_URL=https://typesense.elte.hu/multi_search
DOCUMENTS_TYPESENSE_API_KEY=
DOCUMENTS_SYNC_PER_PAGE=250
DOCUMENTS_REQUEST_TIMEOUT_SECONDS=30

# Legacy scraper envs (unused by current pipeline)
SCRAPE_MANIFEST_PATH=data/runtime/scrape_manifest.json
SCRAPE_DOWNLOAD_PATH=data/raw
SCRAPE_NEWS_PATH=data/scraped_news

# News sync
NEWS_TYPESENSE_URL=https://typesense.elte.hu/multi_search
NEWS_TYPESENSE_API_KEY=
NEWS_RECORDS_PATH=data/news/items
NEWS_STATE_PATH=data/news/state.json
NEWS_FAISS_INDEX_PATH=data/news_vector_store
NEWS_BOOTSTRAP_PAGES=4
NEWS_SYNC_PAGES=2
# Deprecated: periodic scheduler removed; kept only for backward compatibility.
NEWS_SYNC_INTERVAL_SECONDS=21600
NEWS_REQUEST_TIMEOUT_SECONDS=30

# Ingestion/Chunking params
MAX_TOKENS=256
RAW_DATA_PATH=data/raw

# Retrieval parameters
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=30
RETRIEVAL_USE_RERANKER=true
RETRIEVAL_HYBRID=true
RETRIEVAL_HYBRID_WEIGHT=0.6
RETRIEVAL_MAX_CHUNKS_PER_DOC=3

# Reranker model
RERANKER_MODEL=google/gemini-3-flash-preview
RERANKER_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_CROSS_ENCODER_TOP_N=30

# LLM provider: "openrouter" or "ollama" 
LLM_PROVIDER=openrouter

# OpenRouter credentials
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=google/gemini-3-flash-preview

DEFAULT_EMBEDDING_PROFILE=local_minilm
DEFAULT_PIPELINE_MODE=baseline_v1
DEFAULT_RERANKER_MODE=off
DEFAULT_CHUNK_PROFILE=standard
DEFAULT_PARSER_PROFILE=docling_v1

# Local Ollama params
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# API 
API_HOST=127.0.0.1
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
